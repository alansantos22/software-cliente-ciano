# ========================================
# CIANO - Sistema de Cotas
# Variáveis de Ambiente
# ========================================

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_DATABASE=ciano_cotas

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Throttle (Rate Limiting)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug

# Email (SMTP)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=adm@gshark.com.br
MAIL_PASSWORD=your_email_password_here
MAIL_FROM=Ciano Cotas <adm@gshark.com.br>

# Frontend URL (usado nos links de e-mail e no retorno do checkout)
FRONTEND_URL=https://seudominio.com.br

# ========================================
# PagBank / PagSeguro (Checkout - compra de cotas)
# ========================================
# Token de aplicação gerado no painel PagBank.
PAGBANK_TOKEN=your_pagbank_token_here
# Sandbox:  https://sandbox.api.pagseguro.com
# Produção: https://api.pagseguro.com
PAGBANK_BASE_URL=https://sandbox.api.pagseguro.com
# Token usado para validar a assinatura dos webhooks (configurado no painel).
PAGBANK_WEBHOOK_TOKEN=your_pagbank_webhook_token_here
# Texto na fatura do cartão (máx. 17 caracteres).
PAGBANK_SOFT_DESCRIPTOR=CIANO COTAS
# URL pública HTTPS do backend que recebe as notificações do PagBank.
PAGBANK_NOTIFICATION_URL=https://api.seudominio.com.br/api/payments/webhook/pagbank
