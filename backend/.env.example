# ========================================
# CIANO - Sistema de Cotas
# Variáveis de Ambiente
# ========================================

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_DATABASE=ciano_cotas

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Throttle (Rate Limiting)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug

# Email (SMTP)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=adm@gshark.com.br
MAIL_PASSWORD=your_email_password_here
MAIL_FROM=Ciano Cotas <adm@gshark.com.br>

# Frontend URL (usado nos links de e-mail e no retorno do checkout)
FRONTEND_URL=https://seudominio.com.br

# ========================================
# InfinitePay (Checkout Integrado - compra de cotas)
# ========================================
# O Checkout/links NÃO usa token/JWT/API key — a conta é identificada apenas
# pelo handle (InfiniteTag) abaixo, enviado no corpo da requisição.
# InfiniteTag (handle) do lojista, SEM o "$" — identifica a conta que recebe.
INFINITEPAY_HANDLE=your_infinitetag_here
# Produção: https://api.checkout.infinitepay.io
INFINITEPAY_BASE_URL=https://api.checkout.infinitepay.io
# 'true' usa o ambiente de testes (adiciona o header Env: mock).
INFINITEPAY_SANDBOX=true
# URL pública HTTPS do backend que recebe as notificações da InfinitePay.
INFINITEPAY_WEBHOOK_URL=https://api.seudominio.com.br/api/payments/webhook/infinitepay
